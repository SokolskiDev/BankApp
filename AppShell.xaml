<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="BankApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BankApp"
    Title="BankApp"
    Shell.TabBarIsVisible="False"
    Shell.NavBarIsVisible="False"
    >

    <FlyoutItem Title="Bank">

            <ShellContent
            Title="Strona główna"
            Route="MainPage"
            ContentTemplate="{DataTemplate local:MainPage}" />

            <ShellContent
            Title="Strona użytkownika"
            Route="UserPage"
            ContentTemplate="{DataTemplate local:UserPage}" />

            <ShellContent
            Title="BLIK"
            Route="BlikPage"
            ContentTemplate="{DataTemplate local:BlikPage}" />

            <ShellContent
            Title="Przelew na telefon"
            Route="MobileTransferPage"
            ContentTemplate="{DataTemplate local:MobileTransferPage}" />

            <ShellContent
            Title="Pomoc"
            Route="HelpPage"
            ContentTemplate="{DataTemplate local:HelpPage}" />

        </FlyoutItem>

    </Shell>
